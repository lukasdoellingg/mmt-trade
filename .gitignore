# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / tooling caches ──────────────────────────────────────────
.eslintcache
.idea/
.vscode/
*.swp
*.swo

# ── Local Emscripten SDK (downloaded by packages/engine/scripts) ──
packages/engine/.emsdk/
packages/engine/build/
packages/engine/vendor/

# ── Build artifacts ───────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg

# ── Environment and secrets ───────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/

# ── Logs and local data ───────────────────────────────────────────
*.log
logs/
data/
*.db
*.sqlite

# ── OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── pytest / coverage ─────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── mypy ──────────────────────────────────────────────────────────
.mypy_cache/

# ── Node ──────────────────────────────────────────────────────────
node_modules/
test-results/
playwright-report/
playwright/.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Captures, HAR, binary fixtures (large + may contain tokens) ──
*.har
*.bin
*.heapsnapshot
*.cpuprofile
*.dmp
captures/
docs/captures/*.bin
docs/captures/*.har

# Committed test fixtures (mini CBOR columns)
!tests/fixtures/
!tests/fixtures/**

# ── WASM artifacts (generated, not source) ────────────────────────
web/frontend/public/engine.wasm
web/frontend/public/terminal.wasm
web/frontend/public/terminal_smoke.wasm
packages/shell/public/engine.wasm
packages/shell/public/terminal.wasm
packages/shell/public/terminal_smoke.wasm
packages/shell/public/terminal.js
packages/shell/public/terminal_smoke.js
packages/shell/public/*.data
packages/engine/build/
.odin-sdk/

# ── Emscripten SDK (installed per developer, ~1.5 GB) ─────────────
packages/engine/.emsdk/

# ── Vendored third-party engine sources (fetched via install-vendor) ──
packages/engine/vendor/sokol-c/
packages/engine/vendor/sokol-odin/
packages/engine/vendor/cimgui/

# ── Reference MMT binaries (never commit, licensing unclear) ──────
terminal.wasm
terminal.js
terminal.data

# ── Legacy / snapshot directories (removed in Phase 0 cleanup) ─────
# Retained as ignore entries so a stray re-clone of an old snapshot
# can't accidentally re-enter the index.
students_workfolder/
/mmt-trade/
web/legacy-frontend/
services/

packages/shell/public/
web/frontend/public/terminal*
