{
  "name": "mmt-trade",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "web/backend",
    "web/frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --workspace web/backend run dev",
    "dev:frontend": "npm --workspace web/frontend run dev",
    "build": "npm --workspace web/frontend run build",
    "start": "concurrently -n backend,frontend -c cyan,green \"npm run start:backend\" \"npm run preview:frontend\"",
    "start:backend": "npm --workspace web/backend run start",
    "preview:frontend": "npm --workspace web/frontend run build && npm --workspace web/frontend run preview",
    "install:all": "npm install",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:engine": "bash packages/engine/build.sh",
    "lint": "eslint . --ext .ts,.tsx,.vue,.js,.mjs --cache --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx,.vue,.js,.mjs --cache --fix",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,mjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,js,mjs,json,md,yml,yaml}\"",
    "typecheck": "npm --workspace web/frontend exec -- tsc --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "test:mmt-cbor": "node scripts/test-mmt-cbor.mjs",
    "analyze:mmt-har": "node scripts/analyze-mmt-har.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cbor": "^9.0.2",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "prettier": "^3.3.0",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^9.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "odin": "^0.0.10",
    "vue": "^3.5.34"
  }
}
