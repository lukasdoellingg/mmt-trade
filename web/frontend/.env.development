# API direkt zum Backend (Port 3001) – für Charts etc.
VITE_API_URL=http://localhost:3001/api

# Local backend WebSockets (/ws/heatmap) — set 1 only to use /ws/session → MMT API
VITE_USE_SESSION_MUX=0
VITE_USE_EMSCRIPTEN_WORKERS=0
# OB heatmap inside chartEngineWorker (opt-in, default off)
# VITE_USE_EMSCRIPTEN_OB_HEATMAP=1
