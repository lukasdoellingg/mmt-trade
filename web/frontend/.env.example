# Copy to .env.development or .env.local (Vite loads these automatically)

VITE_API_URL=http://localhost:3001/api

# Script indicators + bar stats via backend /ws/session (set 0 to disable)
VITE_USE_SESSION_MUX=1

# 1 = OB heatmap in chartEngineWorker; 0 = legacy /ws/heatmap worker
VITE_USE_EMSCRIPTEN_WORKERS=0

# VITE_USE_EMSCRIPTEN_OB_HEATMAP=1
# VITE_USE_CHART_RUNTIME_INDICATORS=1
