# ── HTTP server ──────────────────────────────────────────────────
PORT=3001

# ── Optional: protect /api/* in production (health stays public) ─
# API_KEY=

# ── CORS allow-list (comma-separated origins) ────────────────────
# Default in dev: http://localhost:5173, http://127.0.0.1:5173, http://localhost:5174
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com

# ── WebSocket security limits ────────────────────────────────────
# WS_MAX_PER_IP=3                    # concurrent sockets per IP
# WS_MAX_PAYLOAD_BYTES=65536         # max inbound frame size

# ── mmt.gg-protocol gateway (Phase 6) ────────────────────────────
# Local WSS endpoint that speaks the mmt.gg /api/v2/ws schema (subscribe,
# getrange, unsubscribe, ping). Stream IDs match captured HAR:
#   4 = candles, 5 = multi-exchange aggregate, 6 = volumes,
#   13 = OB heatmap (with bucket_group), 16 = aggregated trades.
MMT_WS_URL=ws://localhost:3001/api/v2/ws
# When set, the gateway proxies subscribes upstream to the real mmt.gg WS.
# Without it, all streams are served locally from Binance/Bybit public feeds
# or an HAR replay (MMT_REPLAY=path/to.har).
# MMT_UPSTREAM_URL=
# MMT_REPLAY=/Users/me/Downloads/app.mmt.gg.har

# ── Optional: real MMT.gg heatmap data ───────────────────────────
# 1. Log in at https://app.mmt.gg
# 2. DevTools → Network → WS → copy ?token=… from the v2 URL
# 3. Run: npm run setup:mmt -- <paste-token-here>
#    Or set MMT_WS_TOKEN here manually (never commit a real value).
# MMT_WS_TOKEN=
# MMT_WS_HOST=eu-central-2.mmt.gg
# MMT_APP_VERSION=4.2.2
# MMT_GETRANGE_DAYS=7
# MMT_RECONNECT_ATTEMPTS=5
# MMT_WS_MAX_PAYLOAD_BYTES=16777216

# ── Binance fallback depth broadcast ─────────────────────────────
# HEATMAP_MAX_LEVELS=800
# HEATMAP_MAX_BOOK_SIZE=5000
