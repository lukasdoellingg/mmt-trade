# ── HTTP server ──────────────────────────────────────────────────
PORT=3001
# HOST=127.0.0.1                 # bind address (optional; default all interfaces)

# ── CORS allow-list (comma-separated origins) ────────────────────
# Default in dev: http://localhost:5173, http://127.0.0.1:5173
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com

# ── WebSocket security limits ────────────────────────────────────
# WS_MAX_PER_IP=3                    # concurrent /ws/heatmap sockets per IP
# WS_MAX_PAYLOAD_BYTES=65536         # max inbound frame size on /ws/heatmap
# WS_REQUIRE_ORIGIN=1                # reject WS without Origin (default on in production)
# LOG_LEVEL=info                     # error | warn | info | debug

# ── Heatmap / session (first-party only) ─────────────────────────
# Heatmap: /ws/heatmap — Binance or Binance+Bybit aggregate
# Info stream: /ws/session — local script plots + bar stats (no token)

# ── Binance depth broadcast ──────────────────────────────────────
# HEATMAP_MAX_LEVELS=800
# HEATMAP_MAX_BOOK_SIZE=5000
